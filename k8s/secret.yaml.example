# Copy to secret.yaml and fill in values. Do not commit secret.yaml.
# kubectl create secret generic expense-tracker-api-secret --from-literal=... -n expense-tracker
# Or apply this (with real values encoded in base64):
apiVersion: v1
kind: Secret
metadata:
  name: expense-tracker-api-secret
  namespace: expense-tracker
  labels:
    app: expense-tracker-api
type: Opaque
stringData:
  DATABASE_URL: "postgresql://user:password@host:5432/dbname?schema=public"
  JWT_SECRET: "your-jwt-secret-min-32-chars"
  BASE_URL: "https://your-api.example.com"
  # Optional OAuth
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  # FACEBOOK_APP_ID: ""
  # FACEBOOK_APP_SECRET: ""
