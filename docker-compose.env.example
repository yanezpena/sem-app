# Copy to .env and set for Docker Compose (e.g. cp docker-compose.env.example .env)
# Optional: defaults in docker-compose.yml work for local dev.

# PostgreSQL (host port 5433 avoids conflict with existing Postgres on 5432)
POSTGRES_DB=expense_tracker
POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
POSTGRES_PORT=5433

# API
API_PORT=3000
JWT_SECRET=your-secret-key-min-32-chars
BASE_URL=http://localhost:3000

# Web app: URL the browser uses to call the API
WEB_PORT=8080
EXPO_PUBLIC_API_URL=http://localhost:3000

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
