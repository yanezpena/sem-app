# For physical device: use your machine's IP instead of localhost
# iOS Simulator / Android Emulator: localhost usually works
EXPO_PUBLIC_API_URL=http://localhost:3000

# OAuth Configuration (for web login in the mobile app)
# This should be the "Web application" OAuth client ID from Google Cloud Console
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_google_client_id
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id_for_mobile

# OAuth Endpoints
EXPO_PUBLIC_GOOGLE_AUTH_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
EXPO_PUBLIC_FACEBOOK_AUTH_ENDPOINT=https://www.facebook.com/v12.0/dialog/oauth
